	$(MAKE) $(MAKESILENT) -f CMakeFiles/game_engine.dir/build.make CMakeFiles/game_engine.dir/src/ThirdParty/lua/lzio.c.i
.PHONY : src/ThirdParty/lua/lzio.c.i

src/ThirdParty/lua/lzio.s: src/ThirdParty/lua/lzio.c.s
.PHONY : src/ThirdParty/lua/lzio.s

# target to generate assembly for a file
src/ThirdParty/lua/lzio.c.s:
